#!/bin/bash

CONFIG_FILE="/etc/marzban_cleanup.conf"
SCRIPT_URL="https://raw.githubusercontent.com/indie-master/marzban-log-cleaner/main/marzban-log"
SCRIPT_PATH="/usr/local/bin/marzban-log"
DEFAULT_ACCESS_LOG="/var/lib/marzban/access.log"
DEFAULT_ERROR_LOG="/var/lib/marzban/error.log"
DEFAULT_NODE_ACCESS_LOG="/var/lib/marzban-node/access.log"
DEFAULT_NODE_ERROR_LOG="/var/lib/marzban-node/error.log"
DEFAULT_CLEAN_INTERVAL="12"

validate_interval() {
    local value="$1"
    if [[ "$value" =~ ^[0-9]+$ ]] && [ "$value" -gt 0 ]; then
        echo "$value"
    else
        echo ""
    fi
}

write_config() {
    sudo tee "$CONFIG_FILE" > /dev/null <<EOF
ACCESS_LOG="${ACCESS_LOG:-$DEFAULT_ACCESS_LOG}"
ERROR_LOG="${ERROR_LOG:-$DEFAULT_ERROR_LOG}"
NODE_ACCESS_LOG="${NODE_ACCESS_LOG:-$DEFAULT_NODE_ACCESS_LOG}"
NODE_ERROR_LOG="${NODE_ERROR_LOG:-$DEFAULT_NODE_ERROR_LOG}"
CLEAN_INTERVAL="${CLEAN_INTERVAL:-$DEFAULT_CLEAN_INTERVAL}"
BACKUP_ENABLED="${BACKUP_ENABLED:-no}"
BACKUP_DIR="${BACKUP_DIR:-}"
EOF
}

# Проверяем и создаем конфигурацию
ensure_config() {
    if [ ! -f "$CONFIG_FILE" ]; then
        echo "Создание конфигурации..."
        ACCESS_LOG="$DEFAULT_ACCESS_LOG"
        ERROR_LOG="$DEFAULT_ERROR_LOG"
        NODE_ACCESS_LOG="$DEFAULT_NODE_ACCESS_LOG"
        NODE_ERROR_LOG="$DEFAULT_NODE_ERROR_LOG"
        CLEAN_INTERVAL="$DEFAULT_CLEAN_INTERVAL"
        BACKUP_ENABLED="no"
        BACKUP_DIR=""
        write_config
    fi
}

# Установка скрипта
install_script() {
    echo "Установка marzban-log..."
    sudo curl -o "$SCRIPT_PATH" -L "$SCRIPT_URL"
    sudo chmod +x "$SCRIPT_PATH"
    ensure_config
    setup_cron
    echo "Установка завершена! Используйте 'marzban-log' для управления."
}

# Настройка cron
setup_cron() {
    ensure_config
    source "$CONFIG_FILE"
    local validated_interval
    validated_interval=$(validate_interval "$CLEAN_INTERVAL")
    if [ -z "$validated_interval" ]; then
        echo "Некорректное значение CLEAN_INTERVAL=$CLEAN_INTERVAL. Используется значение по умолчанию: $DEFAULT_CLEAN_INTERVAL"
        CLEAN_INTERVAL="$DEFAULT_CLEAN_INTERVAL"
        write_config
        validated_interval="$DEFAULT_CLEAN_INTERVAL"
    fi
    local new_cron="0 */$validated_interval * * * $SCRIPT_PATH clean"
    (sudo crontab -l 2>/dev/null | grep -v "$SCRIPT_PATH") | sudo crontab -
    (sudo crontab -l 2>/dev/null; echo "$new_cron") | sudo crontab -
    echo "Cron обновлён: $new_cron"
}

# Проверка и создание папки для бэкапов
ensure_backup_dir() {
    if [ "$BACKUP_ENABLED" == "yes" ]; then
        if [ -z "$BACKUP_DIR" ]; then
            echo "Бэкапы включены, но путь BACKUP_DIR не задан. Пропуск резервного копирования."
            return 1
        fi
        if [ ! -d "$BACKUP_DIR" ]; then
            echo "Создание директории для бэкапов: $BACKUP_DIR"
            sudo mkdir -p "$BACKUP_DIR"
        fi
    fi
}

# Очистка логов
cleanup_logs() {
    ensure_config
    source "$CONFIG_FILE"
    ensure_backup_dir
    timestamp=$(date +"%Y%m%d_%H%M%S")

    process_log() {
        local log_file="$1"
        if [ -f "$log_file" ]; then
            if [ "$BACKUP_ENABLED" == "yes" ] && [ -n "$BACKUP_DIR" ]; then
                sudo cp "$log_file" "$BACKUP_DIR/$(basename "$log_file")_$timestamp"
            fi
            sudo truncate -s 0 "$log_file"
            echo "Очищен: $log_file"
        else
            echo "Файл не найден: $log_file"
        fi
    }

    process_log "$ACCESS_LOG"
    process_log "$ERROR_LOG"
    process_log "$NODE_ACCESS_LOG"
    process_log "$NODE_ERROR_LOG"
}

# Изменение настроек
config_script() {
    ensure_config
    while true; do
        source "$CONFIG_FILE"
        echo "=== Настройки marzban-log ==="
        echo "1) Изменить частоту очистки (текущая: ${CLEAN_INTERVAL} ч.)"
        echo "2) Переключить резервное копирование (сейчас: $BACKUP_ENABLED)"
        echo "3) Указать папку для бэкапов (текущая: ${BACKUP_DIR:-не задана})"
        echo "4) Выход"
        read -p "Выберите опцию: " choice

        case $choice in
            1)
                read -p "Введите новую частоту очистки (в часах): " new_interval
                local validated
                validated=$(validate_interval "$new_interval")
                if [ -n "$validated" ]; then
                    CLEAN_INTERVAL="$validated"
                    echo "Частота очистки обновлена: ${CLEAN_INTERVAL} ч."
                else
                    echo "Некорректное значение: $new_interval"
                    continue
                fi
                ;;
            2)
                read -p "Включить бэкапы? (yes/no): " new_backup
                new_backup=$(echo "$new_backup" | tr '[:upper:]' '[:lower:]')
                if [[ "$new_backup" == "yes" || "$new_backup" == "no" ]]; then
                    BACKUP_ENABLED="$new_backup"
                    echo "Резервное копирование: $BACKUP_ENABLED"
                else
                    echo "Введите 'yes' или 'no'."
                    continue
                fi
                ;;
            3)
                read -p "Введите путь для бэкапов: " new_dir
                BACKUP_DIR="$new_dir"
                echo "Папка бэкапов: ${BACKUP_DIR:-не задана}"
                ;;
            4)
                break
                ;;
            *)
                echo "Неверный ввод."
                continue
                ;;
        esac

        write_config
        setup_cron
        echo "Настройки сохранены."
    done
}

# Обновление скрипта
update_script() {
    echo "Обновление marzban-log..."
    sudo curl -o "$SCRIPT_PATH" -L "$SCRIPT_URL"
    sudo chmod +x "$SCRIPT_PATH"
    echo "Обновление завершено!"
}

# Вывод статуса
show_status() {
    ensure_config
    source "$CONFIG_FILE"
    echo "=== Текущие настройки ==="
    cat "$CONFIG_FILE"
}

# Вывод справки
show_help() {
    echo "=== Доступные команды ==="
    echo "  marzban-log          - Показать список команд"
    echo "  marzban-log clean    - Очистить логи вручную"
    echo "  marzban-log update   - Обновить скрипт"
    echo "  marzban-log status   - Показать текущие настройки"
    echo "  marzban-log install  - Установить и настроить скрипт"
    echo "  marzban-log config   - Изменить настройки"
}

# Обработка аргументов
arg="${1:-}"

case "$arg" in
    install) install_script ;;
    clean) cleanup_logs ;;
    update) update_script ;;
    status) show_status ;;
    config) config_script ;;
    *) show_help ;;
esac

